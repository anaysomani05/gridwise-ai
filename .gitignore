# ============================================================
# GridWise — root .gitignore
# ============================================================


# ------------------------------------------------------------
# Environment / secrets — NEVER commit these
# ------------------------------------------------------------
.env
.env.local
.env.*.local
*.env


# ------------------------------------------------------------
# Python
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Virtual environments
.venv/
venv/
env/
ENV/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/

# pytest / coverage
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# mypy / type checkers
.mypy_cache/
.dmypy.json
.pyre/
.pytype/

# Jupyter
.ipynb_checkpoints/


# ------------------------------------------------------------
# Node / frontend
# ------------------------------------------------------------
node_modules/
dist/
.next/
.nuxt/
.output/
.cache/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Lock files (keep one, ignore others as needed)
# Uncomment the ones you don't use:
# package-lock.json
# yarn.lock
# pnpm-lock.yaml


# ------------------------------------------------------------
# OS / editor artifacts
# ------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# VSCode
.vscode/
!.vscode/extensions.json

# JetBrains IDEs
.idea/

# Vim / Emacs
*.swp
*.swo
*~
\#*\#


# ------------------------------------------------------------
# Misc
# ------------------------------------------------------------
*.log
*.tmp
*.bak
*.orig
