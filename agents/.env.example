# ============================================================
# GridWise Agent Layer — Environment Variables
# Copy this file to .env and fill in your real values.
#   cp .env.example .env
# NEVER commit .env to version control.
# ============================================================


# ------------------------------------------------------------
# Google Gemini API (required for /explain and /explain/audio)
# Get your key at: https://aistudio.google.com/app/apikey
# ------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# Gemma model ID to use via the Gemini API.
# Default: gemma-3-27b-it
# Override when Gemma 4 becomes available: gemma-4-27b-it
GEMMA_MODEL=gemma-3-27b-it


# ------------------------------------------------------------
# ElevenLabs TTS (optional — only needed for /explain/audio)
# Get your key at: https://elevenlabs.io
# ------------------------------------------------------------
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Voice ID to use. Default is "Rachel" (free tier).
# Find voice IDs at: https://api.elevenlabs.io/v1/voices
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# TTS model. Default: eleven_turbo_v2 (low latency, good quality)
ELEVENLABS_MODEL_ID=eleven_turbo_v2


# ------------------------------------------------------------
# Backboard (persistent AI memory)
# Get your key at: https://backboard.io
# ------------------------------------------------------------
BACKBOARD_API_KEY=your_backboard_api_key_here

# Assistant ID created in your Backboard dashboard
BACKBOARD_ASSISTANT_ID=your_backboard_assistant_id_here

# Thread ID to post optimization run messages into
BACKBOARD_THREAD_ID=your_backboard_thread_id_here


# ------------------------------------------------------------
# Auth0 AI (authentication + AI-aware access control)
# Get your credentials at: https://auth0.com/ai
# Docs: https://developer.auth0.com/resources/labs/auth0-ai
# ------------------------------------------------------------

# API key for Auth0 AI features
AUTH0_AI_API_KEY=your_auth0_ai_api_key_here

# Your Auth0 tenant domain (e.g. your-tenant.us.auth0.com)
AUTH0_DOMAIN=your_tenant.us.auth0.com

# Application client ID from your Auth0 dashboard
AUTH0_CLIENT_ID=your_auth0_client_id_here

# Application client secret from your Auth0 dashboard
AUTH0_CLIENT_SECRET=your_auth0_client_secret_here

# API audience identifier (matches the API you registered in Auth0)
AUTH0_AUDIENCE=https://your-api-identifier


# ------------------------------------------------------------
# Agent server settings
# ------------------------------------------------------------

# Port the FastAPI agent layer listens on.
# Default: 8001  (backend uses 8000, so we stay out of its way)
AGENT_PORT=8001

# Set to "true" in development for hot-reload, "false" in production.
RELOAD=true


# ------------------------------------------------------------
# Backend URL (used if agent layer ever needs to call /optimize directly)
# ------------------------------------------------------------
BACKEND_URL=http://localhost:8000
